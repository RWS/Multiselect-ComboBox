<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DropDown Button -->
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.Button.Background" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.Button.Border" Color="{DynamicResource {x:Static SystemColors.ActiveBorderColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.Button.Disabled.Background" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.Button.Disabled.Border" Color="{DynamicResource {x:Static SystemColors.GrayTextColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.Button.Disabled.Foreground" Color="{DynamicResource {x:Static SystemColors.GrayTextColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.Button.MouseOver.Background" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.Button.MouseOver.Border" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.Button.Pressed.Background" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.Button.Pressed.Border" Color="{DynamicResource {x:Static SystemColors.HighlightTextColorKey}}"/>

    <!-- DropDown ListBox Group Header -->
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.ListBox.GroupHeader.Background" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.ListBox.GroupHeader.Foreground" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}"/>

    <!-- DropDown ListBox Items -->
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.ListBoxItem.SelectedOrder.Foreground" Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.ListBoxItem.Selector.Background" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.ListBoxItem.Selector.Border" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.ListBoxItem.Selected.Background" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.ListBoxItem.Selected.Border" Color="{DynamicResource {x:Static SystemColors.HighlightTextColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.DropDown.ListBoxItem.Selected.Foreground" Color="{DynamicResource {x:Static SystemColors.HighlightTextColorKey}}"/>

    <!-- Selected Items Panel -->
    <SolidColorBrush x:Key="MultiSelectComboBox.SelectedItem.Border" Color="{DynamicResource {x:Static SystemColors.ActiveBorderColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.SelectedItem.Button.Foreground" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.SelectedItem.Button.Hover.Background" Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.SelectedItem.Button.Light.Foreground" Color="{DynamicResource {x:Static SystemColors.ControlTextColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.SelectedItemsPanel.Border" Color="{DynamicResource {x:Static SystemColors.ActiveBorderColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.SelectedItemsPanel.Background" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}"/>

    <!-- Text -->
    <FontFamily x:Key="MultiSelectComboBox.Text.FontFamily">Segoe UI</FontFamily>
    <SolidColorBrush x:Key="MultiSelectComboBox.Text.Disabled.Foreground" Color="{DynamicResource {x:Static SystemColors.GrayTextColorKey}}"/>
    <SolidColorBrush x:Key="MultiSelectComboBox.Text.Foreground" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}"/>

    <!-- No Results -->
    <SolidColorBrush x:Key="MultiSelectComboBox.NoResults.Border" Color="{DynamicResource {x:Static SystemColors.ActiveBorderColorKey}}"/>

    <!-- AutoComplete TextBox -->
    <Thickness x:Key="MultiSelectComboBox.AutoComplete.TextBox.Margin">-8,5,0,0</Thickness>
    <Thickness x:Key="MultiSelectComboBox.AutoComplete.TextBox.Padding">-3,1,0,1</Thickness>

</ResourceDictionary>